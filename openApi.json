{
  "openapi": "3.0.3",
  "info": {
    "title": "Signal K AJRM Marine Snapshot",
    "version": "0.5.4",
    "description": "Local snapshot endpoints for a compact Signal K JSON payload intended for manual ChatGPT copy/paste."
  },
  "servers": [
    {
      "url": "/plugins/signalk-ajrm-marine-snapshot"
    }
  ],
  "paths": {
    "/snapshot": {
      "get": {
        "summary": "Build a compact Signal K snapshot",
        "parameters": [
          {
            "name": "includeAllTargets",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "includeNotifications",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "includeElectrical",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "includeAisPlusHarbourRegions",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "includeDebugRaw",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "includeInstalledApps",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "maxTargetAgeSeconds",
            "in": "query",
            "schema": {
              "type": "number",
              "minimum": 1
            }
          },
          {
            "name": "maxAisRangeNm",
            "in": "query",
            "schema": {
              "type": "number",
              "minimum": 0.1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Snapshot JSON"
          },
          "403": {
            "description": "Remote access is disabled"
          }
        }
      }
    },
    "/settings": {
      "get": {
        "summary": "Read effective plugin settings for the web UI",
        "responses": {
          "200": {
            "description": "Effective settings"
          },
          "403": {
            "description": "Remote access is disabled"
          }
        }
      }
    }
  }
}
